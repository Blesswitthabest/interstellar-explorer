<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} | Drift Logs</title>
    <link rel="stylesheet" href="/styles/site.css" />
  </head>

  <body>
    <header class="header">
      <div class="wrap header-inner">
        <a class="logo" href="/">Drift Logs</a>
        <nav class="nav">
          <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
          <a href="/about/" {% if page.url contains "/about" %}aria-current="page"{% endif %}>About</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      {{ content }}
    </main>

    <footer class="footer">
      <div class="wrap">
        <p class="muted">Built for class with 11ty. Signal may be delayed.</p>
      </div>
    </footer>
  </body>
</html>
